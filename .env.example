# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Twelve Data API key (free at https://twelvedata.com/register)
# Replaces Yahoo Finance — works from cloud servers (Railway, Heroku, etc.)
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# How often to scan all watchlisted symbols (in minutes). Default: 15
SCAN_INTERVAL_MINUTES=15

# Alert when price is within this % of the 200-day EMA. Default: 2 (= 2%)
EMA200_THRESHOLD_PERCENT=2

# Cooldown between EMA200 proximity alerts for the same symbol (in hours). Default: 4
EMA200_COOLDOWN_HOURS=4

# Alert when VIX moves this % from the price at the last VIX alert. Default: 5 (= 5%)
VIX_CHANGE_THRESHOLD_PERCENT=5
